{
  "name": "node",
  "version": "1.0.0",
  "description": "Node.js app on docker container",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx src/server.ts",
    "debug": "node --import tsx --inspect=0.0.0.0:9229 src/server.ts",
    "dev:watch": "tsx watch src/server.ts",
    "test": "npx prisma generate && vitest run",
    "test:watch": "npx prisma generate && npx tsx src/tests/integration/queue.test.ts",
    "db:seed": "npx prisma generate && node src/prisma/seed.ts",
    "start:workers": "tsx src/workers/index.ts",
    "start": "tsx src/server.ts"
  },
  "prisma": {
    "seed": "node src/prisma/seed.ts"
  },
  "dependencies": {
    "@bull-board/api": "^8.0.1",
    "@bull-board/express": "^8.0.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/dotenv": "^6.1.1",
    "bullmq": "^5.76.10",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0",
    "stripe": "^22.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@prisma/config": "^7.8.0",
    "@types/node": "^26.0.0",
    "bcrypt": "^6.0.0",
    "nodemon": "^3.1.14",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "directories": {
    "lib": "lib",
    "test": "tests"
  },
  "keywords": []
}